        <mxCell id="ig6d69P2LdZAZRiHEnW5-87" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;rotation=0;" value="10.2. atualizar vendas totais" vertex="1">
