          <mxGeometry height="30" width="140" x="600" y="890" as="geometry" />
        </mxCell>
        <mxCell id="2jVdxNSPYJe4SkIdl3XK-52" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="10.2. Apresenta Mensagem de Sucesso" vertex="1">
          <mxGeometry height="30" width="230" x="230" y="950" as="geometry" />
        </mxCell>
        <mxCell id="2jVdxNSPYJe4SkIdl3XK-53" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="9.1. mostra erro &quot;Árbitro indisponível&quot;" vertex="1">
          <mxGeometry height="30" width="240" x="230" y="1030" as="geometry" />
        </mxCell>
        <mxCell id="2jVdxNSPYJe4SkIdl3XK-54" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="8.1. mostra erro &quot;Selecione um árbitro&quot;" vertex="1">
          <mxGeometry height="30" width="240" x="225" y="1110" as="geometry" />
        </mxCell>
        <mxCell id="2jVdxNSPYJe4SkIdl3XK-55" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="4.1. mostra erro &quot;Jogo Inexistente&quot;" vertex="1">
          <mxGeometry height="30" width="240" x="225" y="1200" as="geometry" />
        </mxCell>
        <mxCell id="CSiy0l2S--uN60dr2ahK-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;p&gt;Caso de Uso: Atribuir Árbitro a Jogo&lt;/p&gt;&lt;p&gt;Ator Principal:&lt;br&gt;Administrador&lt;/p&gt;&lt;p&gt;Atores Secundários:&lt;br&gt;Sistema Mundial 2026&lt;br&gt;Gestão de Jogos&lt;br&gt;Jogo&lt;br&gt;Árbitro&lt;/p&gt;&lt;p&gt;Descrição:&lt;br&gt;Este caso de uso permite ao Administrador atribuir um árbitro a um jogo registado no sistema Mundial 2026. O Administrador inicia sessão, acede à área de gestão de jogos, seleciona o jogo pretendido e escolhe a opção para atribuir um árbitro. O sistema apresenta a lista de árbitros disponíveis e, após a seleção, verifica a disponibilidade do árbitro escolhido. Caso o árbitro esteja disponível, o sistema associa-o ao jogo e apresenta uma mensagem de sucesso.&lt;/p&gt;&lt;p&gt;Pré-condições:&lt;br&gt;O Administrador tem de estar autenticado no sistema.&lt;br&gt;O jogo tem de estar registado no sistema.&lt;br&gt;O jogo selecionado tem de existir.&lt;br&gt;Tem de existir pelo menos um árbitro registado no sistema.&lt;br&gt;O árbitro selecionado tem de estar disponível para o jogo escolhido.&lt;/p&gt;&lt;p&gt;Fluxo Principal:&lt;/p&gt;&lt;ol&gt;&lt;li&gt;&lt;p&gt;O Administrador inicia sessão no sistema.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;O sistema valida a autenticação do Administrador.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;O Administrador acede à área de gestão de jogos.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;O sistema carrega a lista de jogos registados.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;O sistema apresenta os jogos disponíveis.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;O Administrador seleciona o jogo pretendido.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;O sistema obtém os detalhes do jogo selecionado.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;O sistema devolve os detalhes do jogo.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;O Administrador escolhe a opção &quot;Atribuir Árbitro&quot;.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;O sistema obtém a lista de árbitros disponíveis.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;O sistema apresenta a lista de árbitros disponíveis.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;O Administrador seleciona o árbitro pretendido.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;O sistema verifica a disponibilidade do árbitro selecionado.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;O sistema confirma que o árbitro está disponível.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;O sistema associa o árbitro ao jogo.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;O sistema confirma que o árbitro foi associado.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;O sistema apresenta uma mensagem de sucesso ao Administrador.&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;Fluxos Alternativos:&lt;br&gt;A1 — Árbitro indisponível:&lt;br&gt;Se o árbitro selecionado não estiver disponível para o jogo escolhido, o sistema apresenta a mensagem de erro &quot;Árbitro indisponível&quot; e impede a associação ao jogo.&lt;/p&gt;&lt;p&gt;A2 — Nenhum árbitro selecionado:&lt;br&gt;Se o Administrador tentar confirmar a operação sem selecionar um árbitro, o sistema apresenta a mensagem &quot;Selecione um árbitro&quot; e não guarda qualquer alteração.&lt;/p&gt;&lt;p&gt;A3 — Jogo inexistente:&lt;br&gt;Se o jogo selecionado não existir ou já não estiver disponível no sistema, o sistema apresenta a mensagem de erro &quot;Jogo inexistente&quot; e impede a atribuição do árbitro.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="1230" width="290" x="1270" y="200" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
